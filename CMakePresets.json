{
  "version": 3,
  "configurePresets": [
    {
      "name": "windows-clangcl-debug",
      "displayName": "Windows ClangCL Debug",
      "generator": "Visual Studio 18 2026",
      "binaryDir": "${sourceDir}/build",
      "architecture": {
        "value": "x64",
        "strategy": "set"
      },
      "toolset": {
        "value": "ClangCL",
        "strategy": "set"
      },
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "debug",
      "configurePreset": "windows-clangcl-debug",
      "configuration": "Debug"
    }
  ]
}
